<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.bi.mapper.BiDashboardMapper">

    <resultMap type="com.ruoyi.bi.domain.BiDashboard" id="BiDashboardResult">
        <result property="id"          column="id"           />
        <result property="name"        column="name"         />
        <result property="description" column="description"  />
        <result property="configJson"  column="config_json"  />
        <result property="thumbnail"   column="thumbnail"    />
        <result property="status"      column="status"       />
        <result property="isPublic"    column="is_public"    />
        <result property="accessToken" column="access_token" />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectBiDashboardVo">
        SELECT id, name, description, config_json, thumbnail,
               status, is_public, access_token,
               create_by, create_time, update_by, update_time, remark
        FROM bi_dashboard
    </sql>

    <select id="selectBiDashboardList" parameterType="com.ruoyi.bi.domain.BiDashboard" resultMap="BiDashboardResult">
        <include refid="selectBiDashboardVo"/>
        <where>
            <if test="name != null and name != ''">AND name LIKE '%' || #{name} || '%'</if>
            <if test="status != null">AND status = #{status}</if>
            <if test="isPublic != null">AND is_public = #{isPublic}</if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectBiDashboardById" parameterType="Long" resultMap="BiDashboardResult">
        <include refid="selectBiDashboardVo"/>
        WHERE id = #{id}
    </select>

    <insert id="insertBiDashboard" parameterType="com.ruoyi.bi.domain.BiDashboard" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO bi_dashboard
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="description != null and description != ''">description,</if>
            config_json,
            <if test="thumbnail != null and thumbnail != ''">thumbnail,</if>
            <if test="status != null">status,</if>
            <if test="isPublic != null">is_public,</if>
            <if test="accessToken != null and accessToken != ''">access_token,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="description != null and description != ''">#{description},</if>
            <choose>
                <when test="configJson != null and configJson != ''">#{configJson},</when>
                <otherwise>'{}',</otherwise>
            </choose>
            <if test="thumbnail != null and thumbnail != ''">#{thumbnail},</if>
            <if test="status != null">#{status},</if>
            <if test="isPublic != null">#{isPublic},</if>
            <if test="accessToken != null and accessToken != ''">#{accessToken},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            NOW()
        </trim>
    </insert>

    <update id="updateBiDashboard" parameterType="com.ruoyi.bi.domain.BiDashboard">
        UPDATE bi_dashboard
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="configJson != null and configJson != ''">config_json = #{configJson},</if>
            <if test="thumbnail != null">thumbnail = #{thumbnail},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
            <if test="accessToken != null">access_token = #{accessToken},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = NOW()
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteBiDashboardById" parameterType="Long">
        DELETE FROM bi_dashboard WHERE id = #{id}
    </delete>

    <delete id="deleteBiDashboardByIds" parameterType="String">
        DELETE FROM bi_dashboard WHERE id IN
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
